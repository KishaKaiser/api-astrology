generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  kvEntries    KVEntry[]
}

model KVEntry {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model ReportRequest {
  id        String   @id @default(cuid())
  reportId String   @unique
  orderId   String?
  productName String?
  formData  Json
  reportText String @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
